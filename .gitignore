# Environment variables — never commit
.env
.env.local
.env.*
!.env.example

# Logs
*.log
logs/

# OS / editor noise
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/

# Python (the bulk of Python code lives in mcp-server/ which has its
# own .gitignore covering .venv + caches; this catches stray bytecode
# at the repo root if any tooling drops it.)
__pycache__/
*.py[cod]

# Node (no Node code in this project, but keep these excluded in case
# any tooling drops them at the repo root during development)
node_modules/
