# Environment variables — never commit
.env
.env.local
.env.*
!.env.example

# Logs — generally ignored, but the canonical per-query traces under
# logs/query-*.log are deliverables (README references them) so they
# are explicitly un-ignored. Note the `logs/*` instead of `logs/`:
# git won't descend into an ignored directory, so we have to ignore
# the children individually and then negate the canonical traces.
*.log
logs/*
!logs/query-*.log

# OS / editor noise
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/

# Python — uv venv + bytecode caches
.venv/
__pycache__/
*.py[cod]

# Agent6 runtime state — durable memory + artifacts + run traces.
# Per the assignment: state/ must be cleanable between attempts, so it
# stays out of version control. README documents `rm -rf state/`.
state/

# MCP server's file-tool sandbox + its usage log
sandbox/
usage.json

# Node (no Node code in this project, but keep these excluded in case
# any tooling drops them at the repo root during development)
node_modules/
