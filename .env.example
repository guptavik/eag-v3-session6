# Tavily web search (optional — falls back to DuckDuckGo if missing).
# Sign up at https://tavily.com — free tier covers light use.
TAVILY_API_KEY=

# Where agent6.py finds the LLM Gateway V3. Start the gateway with:
#   cd mcp-server/llm_gatewayV3 && ./run.sh
# Then it listens on http://localhost:8101.
LLM_GATEWAY_V3_URL=http://localhost:8101

# Provider keys consumed by the gateway itself live in
# mcp-server/llm_gatewayV3/.env (or ../.env from the gateway's perspective).
# See mcp-server/llm_gatewayV3/README.md for the full list:
#   GEMINI_API_KEY, GROQ_API_KEY, CEREBRAS_API_KEY, NVIDIA_API_KEY,
#   OPEN_ROUTER_API_KEY, GITHUB_ACCESS_TOKEN, OLLAMA_URL, ...
