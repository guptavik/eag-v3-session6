# Copy this file to `.env` and fill in your keys.
# .env is git-ignored.

# SerpAPI (Google SERP scraper) — used by searchWebInfo and
# analyzeAttendeeBackground when fresh web data or LinkedIn URLs are
# needed. Sign up at https://serpapi.com — the "Free" plan gives
# 100 searches/month, 250/hour. Quota is rationed: searchWebInfo
# tries Gemini first and only falls back to SerpAPI when it doesn't
# know the entity (or when the query asks for fresh / recent info).
SERPAPI_API_KEY=

# Gemini API — used by the server for tiered decisions ("do we know
# this entity?" gating before paying SerpAPI quota) and for synthesizing
# attendee profiles from search snippets. The extension stores its own
# copy of this key in chrome.storage.local and is unaffected.
# Get a key at https://aistudio.google.com (free tier covers this use).
# GEMINI_API_KEY and GOOGLE_API_KEY are both accepted — set whichever
# matches your conventions. (Google AI Studio uses GOOGLE_API_KEY.)
GEMINI_API_KEY=
# GOOGLE_API_KEY=

# Comma-separated list of email domains treated as "internal" — the
# user's own company. Attendees from these domains get a stub profile
# with zero API calls (saves SerpAPI quota and avoids researching
# colleagues). Leave blank to disable.
# Example: OWN_COMPANY_DOMAIN=acme.com,acme.io
OWN_COMPANY_DOMAIN=

# Google OAuth — used by getUpcomingMeetings (Calendar) and searchGmail (Gmail).
# Console: https://console.cloud.google.com → APIs & Services → Credentials
#  1. Create a project (or pick one).
#  2. Enable BOTH "Google Calendar API" and "Gmail API" in the API Library.
#  3. OAuth consent screen → External → add your Google email as a test user.
#  4. Create OAuth client ID → "Desktop" type → copy ID + secret here.
# The redirect URI used is http://localhost:3737/oauth/google/callback —
# Desktop clients accept any loopback URI without prior registration.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: override the port the MCP server listens on.
# Must match the redirect URI registered (or implied) in your OAuth client.
# PORT=3737

# Optional: tighten DNS-rebinding protection. Default is to DISABLE the
# check entirely (the SDK's exact-match origin list can't whitelist
# chrome-extension://<id> safely because the ID varies per machine).
# Set this only if you know the extension's stable origin and want the
# server to reject anything else. Comma-separated; supports a trailing
# ":*" port wildcard but no other globs.
# MCP_ALLOWED_ORIGINS=chrome-extension://poaijlgkpglnoiepihkhpfjdlglihkpf,http://localhost:3737
