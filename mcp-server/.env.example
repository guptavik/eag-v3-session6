# LLM Gateway V3 — provider keys + model overrides + routing config.
#
# Copy this file to mcp-server/.env and fill in the keys you have.
# The gateway needs AT LEAST ONE worker provider key to be useful; the
# router pool needs at least one router-tier key (Cerebras/Groq/NVIDIA/GitHub).
# Missing keys cause the corresponding provider to be silently skipped.
#
# Read by:  mcp-server/llm_gatewayV3/main.py at startup via
#           load_dotenv(ROOT.parent / ".env")
#
# Never commit this file with real keys filled in — `.env` is gitignored.

# ── Worker pool (one of these is the minimum) ──────────────────────────

# Gemini — free tier 15 RPM / 1,000 RPD. https://aistudio.google.com
# Either name works; either GEMINI_API_KEY or GOOGLE_API_KEY is fine.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# Groq — free tier 30 RPM / 1,000 RPD. https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b

# Cerebras — free tier 30 RPM / 1M tokens-per-day. https://cloud.cerebras.ai
# Note: 8K context cap on free tier.
CEREBRAS_API_KEY=
CEREBRAS_MODEL=zai-glm-4.7

# NVIDIA NIM — free tier 40 RPM. https://build.nvidia.com
NVIDIA_API_KEY=
NVIDIA_MODEL=deepseek-ai/deepseek-v3.2

# OpenRouter — free tier 20 RPM / 50 RPD across all :free models.
# https://openrouter.ai
OPEN_ROUTER_API_KEY=
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# GitHub Models — free for personal accounts; 10–15 RPM / 50–150 RPD,
# hard caps 8K input / 4K output per request.
# https://github.com/marketplace/models
GITHUB_ACCESS_TOKEN=
GITHUB_MODEL=openai/gpt-4.1-mini

# Ollama (local) — leave OLLAMA_MODEL unset to disable.
OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=

# Worker failover order. Leave blank to use the default
# (ollama,gemini,nvidia,groq,cerebras,openrouter,github).
# LLM_ORDER=

# ── Router pool (for auto_route) ───────────────────────────────────────

# Routing classifier order. The agent's perception/memory/decision
# layers use auto_route, which calls one of these tiny models first
# to pick which worker tier handles the work.
ROUTER_ORDER=cerebras,groq,nvidia,github

# Per-router model overrides — only needed if the defaults don't work
# on your account.
# ROUTER_CEREBRAS_MODEL=llama3.1-8b
# ROUTER_GROQ_MODEL=llama-3.3-70b-versatile
# ROUTER_NVIDIA_MODEL=nvidia/llama-3.1-nemotron-nano-8b-v1
# ROUTER_GITHUB_MODEL=microsoft/Phi-4-mini-instruct

# ── Misc ───────────────────────────────────────────────────────────────

# Gateway port (default 8101; client at LLM_GATEWAY_V3_URL must match).
GATEWAY_V3_PORT=8101
